<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\Package.props" />
  <PropertyGroup>
    <AssemblyName>MIR.DirectWriteFontsForAvalonia</AssemblyName>
    <PackageId>MIR.DirectWriteFontsForAvalonia</PackageId>
    <RootNamespace>MIR.DirectWriteFontsForAvalonia</RootNamespace>
    <Title>MIR.DirectWriteFontsForAvalonia</Title>
    <Version>12.1.0.0</Version>
    <Description>Shared DirectWrite font backend for Avalonia 12 on Windows, used by MIR Direct2D and DirectWrite packages.</Description>
    <PackageTags>Avalonia;DirectWrite;Fonts;Win32</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>MIR.Direct2D1ForAvalonia, </_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>MIR.DirectWriteForAvalonia, </_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>ParityTools, </_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>Benchmarks, </_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.1.0" ExcludeAssets="compile" />
    <PackageReference Include="Vortice.Direct2D1" Version="3.8.3" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Avalonia.Base">
      <HintPath>$(NuGetPackageRoot)\\avalonia\\12.1.0\\lib\\net8.0\\Avalonia.Base.dll</HintPath>
    </Reference>
    <Reference Include="Avalonia.Controls">
      <HintPath>$(NuGetPackageRoot)\\avalonia\\12.1.0\\lib\\net8.0\\Avalonia.Controls.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
